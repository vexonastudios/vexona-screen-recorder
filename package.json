{
  "name": "vexona-screen-recorder",
  "version": "1.0.0",
  "description": "Professional screen capture & recording by Vexona Studios",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.vexonastudios.screenrecorder",
    "productName": "Vexona Screen Recorder",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vexonastudios",
        "repo": "vexona-screen-recorder"
      }
    ]
  },
  "author": "Vexona Studios",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
